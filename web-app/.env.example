# Prividium login chain selection
# Provide the A/B vars below when the app must support two login chains.
# The legacy single-chain vars remain as fallbacks when a chain-specific value is missing.

# Chain A (setup refresh writes these `VITE_CHAIN_A_*` values)
VITE_CHAIN_A_API_URL=http://localhost:8000/api
VITE_CHAIN_A_RPC_URL=http://localhost:3050
VITE_CHAIN_A_AUTH_BASE_URL=http://localhost:3001
VITE_CHAIN_A_CHAIN_ID=6565
VITE_CHAIN_A_CHAIN_NAME=Prividium A
VITE_CHAIN_A_NATIVE_CURRENCY_SYMBOL=ETH
VITE_CLIENT_ID_CHAIN_A=chain_a_client_id
VITE_CHAIN_A_COMPANY_NAME="AlphaCorp A™"
VITE_CHAIN_A_ACCENT_COLOR="#2563eb"
VITE_CHAIN_A_COMPANY_ICON="CubeIcon"
# Optional alias names also supported:
VITE_PRIVIDIUM_CHAIN_A_API_URL=
VITE_PRIVIDIUM_CHAIN_A_RPC_URL=
VITE_PRIVIDIUM_CHAIN_A_AUTH_BASE_URL=
VITE_PRIVIDIUM_CHAIN_A_ID=
VITE_PRIVIDIUM_CHAIN_A_NAME=
VITE_PRIVIDIUM_CHAIN_A_NATIVE_CURRENCY_SYMBOL=
VITE_PRIVIDIUM_CHAIN_A_CLIENT_ID=
VITE_PRIVIDIUM_CHAIN_A_COMPANY_NAME=
VITE_PRIVIDIUM_CHAIN_A_ACCENT_COLOR=
VITE_PRIVIDIUM_CHAIN_A_COMPANY_ICON=

# Chain B
VITE_CHAIN_B_API_URL=http://localhost:8300/api
VITE_CHAIN_B_RPC_URL=http://localhost:3051
VITE_CHAIN_B_AUTH_BASE_URL=http://localhost:3301
VITE_CHAIN_B_CHAIN_ID=6566
VITE_CHAIN_B_CHAIN_NAME=Prividium B
VITE_CHAIN_B_NATIVE_CURRENCY_SYMBOL=ETH
VITE_CLIENT_ID_CHAIN_B=chain_b_client_id
VITE_CHAIN_B_COMPANY_NAME="AlphaCorp B™"
VITE_CHAIN_B_ACCENT_COLOR="#0f766e"
VITE_CHAIN_B_COMPANY_ICON="ShieldCheckIcon"
# Optional alias names also supported:
VITE_PRIVIDIUM_CHAIN_B_API_URL=
VITE_PRIVIDIUM_CHAIN_B_RPC_URL=
VITE_PRIVIDIUM_CHAIN_B_AUTH_BASE_URL=
VITE_PRIVIDIUM_CHAIN_B_ID=
VITE_PRIVIDIUM_CHAIN_B_NAME=
VITE_PRIVIDIUM_CHAIN_B_NATIVE_CURRENCY_SYMBOL=
