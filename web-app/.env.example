VITE_PRIVIDIUM_CHAIN_B_COMPANY_NAME=
VITE_PRIVIDIUM_CHAIN_B_ACCENT_COLOR=
VITE_PRIVIDIUM_CHAIN_B_COMPANY_ICON=

# Legacy single-chain fallback
VITE_PRIVIDIUM_API_URL=http://localhost:8000/api
VITE_PRIVIDIUM_RPC_URL=http://localhost:8000/rpc
VITE_PRIVIDIUM_AUTH_BASE_URL=http://localhost:3001
VITE_PRIVIDIUM_CHAIN_ID=6565
VITE_PRIVIDIUM_CHAIN_NAME=Prividium
VITE_PRIVIDIUM_NATIVE_CURRENCY_SYMBOL=ETH
VITE_BACKEND_URL=http://localhost:4340
# IMPORTANT: Contract addresses below are populated by the setup job.
# Do NOT edit them manually; re-run setup to refresh.
VITE_COUNTER_CONTRACT_ADDRESS=0xe441CF0795aF14DdB9f7984Da85CD36DB1B8790d
VITE_CLIENT_ID=placeholder
VITE_COMPANY_NAME="AlphaCorp™"
# App accent color: Examples: #2563eb , #27d66aff , #ff8f39ff , #ff39ceff
VITE_ACCENT_COLOR="#2563eb"
# heroicons. Examples: CubeIcon, BoltIcon, FireIcon, etc.
VITE_COMPANY_ICON="CubeIcon"

# Optional SSO overrides (passkey smart accounts)
 # IMPORTANT: These are populated by the setup job. Do NOT edit manually.
VITE_SSO_CHAIN_ID=
VITE_SSO_CHAIN_NAME=
VITE_SSO_WEBAUTHN_VALIDATOR=
VITE_SSO_ENTRYPOINT=
