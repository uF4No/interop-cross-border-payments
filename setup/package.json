{
  "name": "prividium-setup",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "init:env": "[ -f .env ] || cp .env.example .env",
    "setup": "pnpm run setup:3chain",
    "setup:3chain": "node ./scripts/run-tsx.mjs src/main.ts",
    "setup:update-permissions-compose": "node ./scripts/run-tsx.mjs src/update-permissions-compose.ts",
    "setup:fund-entrypoints": "node ./scripts/run-tsx.mjs src/fund-entrypoints.ts",
    "setup:permissions": "pnpm run setup:3chain",
    "setup:system": "node ./scripts/run-tsx.mjs src/system.ts",
    "setup:app": "node ./scripts/run-tsx.mjs src/app.ts",
    "setup-app": "node ./scripts/run-tsx.mjs src/setup-app.ts",
    "userop:direct": "node ./scripts/run-tsx.mjs src/tools/send-userop-direct.ts",
    "verify:sso": "node ./scripts/run-tsx.mjs src/verify-sso.ts",
    "check:contracts": "node ./scripts/run-tsx.mjs src/verify-sso.ts",
    "refresh:env": "node ./scripts/run-tsx.mjs src/refresh-env.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@dotenvx/dotenvx": "^1.51.4",
    "abitype": "^1.2.3",
    "viem": "^2.44.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.15.32",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "undici-types": "^6.20.0"
  }
}
