# Default local admin (Anvil account #0)
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ADMIN_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
# Optional, defaults to ADMIN_PRIVATE_KEY when omitted
EXECUTOR_PRIVATE_KEY=

# Canonical output file
CONTRACTS_CONFIG_PATH="../config/contracts.json"

# System contract addresses (same across chains in this local stack)
NATIVE_TOKEN_VAULT_ADDRESS=0x0000000000000000000000000000000000010004
L2_INTEROP_CENTER_ADDRESS=0x0000000000000000000000000000000000010010
L2_ASSET_ROUTER_ADDRESS=0x0000000000000000000000000000000000010003
L2_STANDARD_TRIGGER_ACCOUNT_ADDRESS=0x000000000000000000000000000000000001000F
INTEROP_GAS_LIMIT=30000000
INTEROP_GAS_PRICE_PER_PUBDATA=800
INTEROP_FEE_WEI=1000000000000000
# Optional relay status endpoint used to wait for cross-chain completion.
INTEROP_BROADCASTER_API_URL=
# Destination-chain signer used by the interop relay.
INTEROP_RELAY_ADDRESS=0x36615Cf349d7F6344891B1e7CA7C72883F5dc049

# Chain A (6565)
CHAIN_A_CHAIN_ID=6565
CHAIN_A_RPC_URL=http://localhost:3050
CHAIN_A_API_URL=http://localhost:8000/api
CHAIN_A_AUTH_BASE_URL=http://localhost:3001
CHAIN_A_ENTRYPOINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108

# Chain B (6566)
CHAIN_B_CHAIN_ID=6566
CHAIN_B_RPC_URL=http://localhost:3051
CHAIN_B_API_URL=http://localhost:8300/api
CHAIN_B_AUTH_BASE_URL=http://localhost:3301
CHAIN_B_ENTRYPOINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108

# Chain C (6567)
CHAIN_C_CHAIN_ID=6567
CHAIN_C_RPC_URL=http://localhost:3052
CHAIN_C_API_URL=http://localhost:8600/api
CHAIN_C_AUTH_BASE_URL=http://localhost:3601
CHAIN_C_ENTRYPOINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108

# Entrypoint funding (chains A/B)
# If an entrypoint balance is below MIN, setup tops it up to TARGET.
ENTRYPOINT_MIN_BALANCE_WEI=10000000000000000
ENTRYPOINT_TARGET_BALANCE_WEI=50000000000000000

# Token deployment and minting
TOKEN_USDC_NAME=USD Coin
TOKEN_USDC_SYMBOL=USDC
TOKEN_USDC_DECIMALS=18
TOKEN_SGD_NAME=Singapore Dollar
TOKEN_SGD_SYMBOL=SGD
TOKEN_SGD_DECIMALS=18
TOKEN_TBILL_NAME=Tokenized Treasury Bill
TOKEN_TBILL_SYMBOL=TBILL
TOKEN_TBILL_DECIMALS=18
# amount minted to deployer per token
TOKEN_PREMINT_AMOUNT=1000000000000000000000000
# one-unit bridging amount used to materialize token addresses on A/B
TOKEN_BRIDGE_PROBE_AMOUNT=1

# InvoicePayment setup
INVOICE_CONTRACT_INITIAL_ETH=1000000000000000000

# Exchange rates (18 decimals fixed-point)
# 1 SGD = 0.74 USDC
RATE_SGD_USDC=740000000000000000
# 1 SGD = 0.74 TBILL
RATE_SGD_TBILL=740000000000000000
# 1 TBILL = 1.02 USDC
RATE_TBILL_USDC=1020000000000000000
# 1 TBILL = 1.38 SGD
RATE_TBILL_SGD=1380000000000000000
# 1 USDC = 1.35 SGD
RATE_USDC_SGD=1350000000000000000
# 1 USDC = 0.98 TBILL
RATE_USDC_TBILL=980000000000000000

# Compatibility aliases used by legacy single-chain scripts (mapped to chain A)
PRIVIDIUM_API_URL=http://localhost:8000/api
PRIVIDIUM_RPC_URL=http://localhost:3050
PRIVIDIUM_AUTH_BASE_URL=http://localhost:3001
PRIVIDIUM_CHAIN_ID=6565
PRIVIDIUM_ENTRYPOINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108

# Legacy app registration keys (kept for setup-app and older flows)
PRIVIDIUM_APP_NAME=local-app
PRIVIDIUM_APP_ORIGIN=http://localhost:3002
PRIVIDIUM_APP_REDIRECT_URIS=http://localhost:3002/auth-callback.html
PRIVIDIUM_APP_CONTRACT_ARTIFACTS=out/InvoicePayment.sol/InvoicePayment.json,out/TestnetERC20Token.sol/TestnetERC20Token.json
