# Environment Configuration
NODE_ENV="development" # Options: 'development', 'production'
PORT="4340"            # The port your server will listen on
HOST="localhost"       # Hostname for the server

# CORS Settings
CORS_ORIGIN="http://localhost:5173" # Allowed CORS origin, adjust as necessary

# Rate Limiting
COMMON_RATE_LIMIT_WINDOW_MS="1000"  # Window size for rate limiting (ms)
COMMON_RATE_LIMIT_MAX_REQUESTS="100" # Max number of requests per window per IP

# 3-chain configuration
# Active backend chain. In local setups this is usually chain A for user traffic.
PRIVIDIUM_CHAIN_A_ID=6565
PRIVIDIUM_CHAIN_B_ID=6566
PRIVIDIUM_CHAIN_C_ID=6567
PRIVIDIUM_CHAIN_ID=6565
PRIVIDIUM_RPC_URL=http://localhost:3050 # Active Prividium RPC
PRIVIDIUM_API_URL=http://localhost:8000/api # Active Prividium API
PRIVIDIUM_AUTH_BASE_URL=http://localhost:3001

# Optional chain-specific overrides synced from config/contracts.json
CHAIN_A_RPC_URL=http://localhost:3050
CHAIN_A_API_URL=http://localhost:8000/api
CHAIN_A_AUTH_BASE_URL=http://localhost:3001
CHAIN_B_RPC_URL=http://localhost:3051
CHAIN_B_API_URL=http://localhost:8300/api
CHAIN_B_AUTH_BASE_URL=http://localhost:3301
CHAIN_C_RPC_URL=http://localhost:3052
CHAIN_C_API_URL=http://localhost:8600/api
CHAIN_C_AUTH_BASE_URL=http://localhost:3601

# Variables
EXECUTOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 # the private key loaded with testnet funds on both L1 and L2
L1_RPC_URL=http://127.0.0.1:8545 # Local Anvil node
L2_INTEROP_CENTER=0xc64315efbdcD90B71B0687E37ea741DE0E6cEFac # Contract address for the L2 Interop Center contract deployed on L2
L1_INTEROP_HANDLER=0xB0dD4151fdcCaAC990F473533C15BcF8CE10b1de # Contract address for the L1 Interop Handler contract deployed on L1
CONTRACTS_CONFIG_PATH=../config/contracts.json # Single source of truth for contract addresses
INVOICE_PAYMENT_CONTRACT= # Optional: InvoicePayment contract address if config/contracts.json is unavailable
TOKEN_USDC_ADDRESS= # Optional fallback token address for minting on the active chain
TOKEN_SGD_ADDRESS= # Optional fallback token address for minting on the active chain
TOKEN_TBILL_ADDRESS= # Optional fallback token address for minting on the active chain
TOKEN_USDC_CHAIN_C_ADDRESS= # Optional chain C token address fallback
TOKEN_SGD_CHAIN_C_ADDRESS= # Optional chain C token address fallback
TOKEN_TBILL_CHAIN_C_ADDRESS= # Optional chain C token address fallback
SSO_FACTORY_CONTRACT= # Optional: override SSO factory contract
SSO_BEACON_CONTRACT= # Optional: override SSO beacon contract
SSO_ACCOUNT_IMPLEMENTATION_CONTRACT= # Optional: override SSO account implementation contract
SSO_EOA_VALIDATOR_CONTRACT= # Optional: override SSO EOA validator contract
SSO_WEBAUTHN_VALIDATOR_CONTRACT= # Optional: override SSO WebAuthn validator contract
SSO_SESSION_VALIDATOR_CONTRACT= # Optional: override SSO session validator contract
SSO_GUARDIAN_EXECUTOR_CONTRACT= # Optional: override SSO guardian executor contract
SSO_ENTRYPOINT_CONTRACT= # Optional: override SSO entry point contract
POLL_INTERVAL=30000 # The ms to wait in between checking the process queue
FINALIZATION_WAIT=900000 # The ms to wait before attempting to finalize a transaction
